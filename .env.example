# WordPress REST API base URL
# ⚠️ Local dev: use the live blog's API URL
# ⚠️ Production (Vercel): set to https://wp-admin.avdesignintl.com/wp-json/wp/v2
WP_API_URL=https://blog.avdesignintl.com/wp-json/wp/v2

# Shared secret between WordPress webhook and Next.js /api/revalidate
# Generate one: openssl rand -hex 32
REVALIDATION_SECRET=change-this-to-a-random-string
